# Sahayak backend — copy to .env and fill in
DEEPSEEK_API_KEY=sk-...

# Model settings
# deepseek-chat = DeepSeek-V3 (fast, good for most tasks)
# deepseek-reasoner = DeepSeek-R1 (slower, better for complex reasoning)
MODEL_CLOUD=deepseek-chat
MODEL_ON_DEVICE=models/gemma-2-2b-it/gemma-2-2b-it.Q4_K_M.gguf

# Storage
LANCEDB_PATH=./data/lancedb
FACE_DB_PATH=./data/faces

# Routing
ON_DEVICE_THRESHOLD=0.7

# Memory
MAX_MEMORY_CHUNKS=10000
EMBEDDING_MODEL=BAAI/bge-m3

# Perception
WHISPER_MODEL=small
FACE_MODEL=buffalo_l
TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Federated Learning
FL_SERVER_ADDRESS=localhost:9090
FL_NUM_ROUNDS=3

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
LOG_LEVEL=INFO
